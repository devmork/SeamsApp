using System.Text;


var builder = WebApplication.CreateBuilder(args);

// REGISTER REPOSITORIES

builder.Services.AddScoped<IStudentRepository, StudentRepository>();
builder.Services.AddScoped<IAttendanceRepository, AttendanceRepository>();  
